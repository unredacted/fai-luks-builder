# UEFI + LUKS + LVM: ESP, /boot, LUKS partition with LVM root and swap

disk_config disk1 disklabel:gpt bootable:1 fstabkey:uuid

primary  /boot/efi  TEMPLATED_EFI_SIZE   vfat   rw
primary  /boot      TEMPLATED_BOOT_SIZE  ext4   rw,noatime
primary  -          0-     -      -

disk_config cryptsetup
luks:"TEMPLATED_LUKS_PASSPHRASE"  -  disk1.3  -  -

disk_config lvm
vg  vg0  disk1.3

vg0-root  /       TEMPLATED_ROOT_SIZE    ext4  rw,noatime,errors=remount-ro
vg0-swap  swap    TEMPLATED_SWAP_SIZE  swap  sw
