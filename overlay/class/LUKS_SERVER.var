# Variables for the LUKS_SERVER class.
# These override values from FAIBASE.var and DEBIAN.var.

# Keyboard layout
KEYMAP=TEMPLATED_KEYBOARD

# System clock
UTC=yes
TIMEZONE=TEMPLATED_TIMEZONE

# Hostname
HOSTNAME=TEMPLATED_DEFAULT_HOSTNAME

# Lock root password -- admin user gets sudo instead
ROOTPW='!'

# Override upstream demo user and disable its weak default password
username=TEMPLATED_ADMIN_USER
USERPW='!'

# Use FAI's maximum package batch for faster installs
MAXPACKAGES=99999
